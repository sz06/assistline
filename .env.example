# ╔══════════════════════════════════════════════════════════════════╗
# ║  Assistline — Environment Variables                             ║
# ║                                                                 ║
# ║  Run `pnpm setup:envs` to auto-generate random values          ║
# ║  and create .env.local files from this template.                ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Dendrite (Matrix Homeserver) ─────────────────────────────────
DENDRITE_SERVER_NAME="matrix.local"
DENDRITE_SHARED_SECRET="GENERATE_ME"

# ─── Matrix Listener Bot ─────────────────────────────────────────
# The bot that syncs WhatsApp messages from Dendrite → Convex.
# On first boot, it auto-registers on Dendrite using the shared secret.
MATRIX_BOT_USERNAME="listener-bot"
MATRIX_BOT_PASSWORD="GENERATE_ME"

# ─── Convex ──────────────────────────────────────────────────────
# Dashboard frontend connects to the Docker-hosted Convex backend.
VITE_CONVEX_URL="http://127.0.0.1:3410"
CONVEX_URL="http://127.0.0.1:3410"

# ─── Tailscale (optional) ────────────────────────────────────────
# Provide a Tailscale auth key to expose the dashboard via Tailscale.
# Leave blank to skip Tailscale setup.
TS_AUTHKEY=""
